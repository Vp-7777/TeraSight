# -----------------------------------------------------------------------------
# TeraSight — Environment Configuration
# Copy to .env and adjust values for your setup.
# -----------------------------------------------------------------------------

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend API
API_HOST=0.0.0.0
API_PORT=8000

# Docker Compose (service hostnames)
DATABASE_URL=postgresql://terasight:terasight@postgres:5432/terasight
REDIS_URL=redis://redis:6379/0
INFERENCE_SERVICE_URL=http://prithviq-inference:8001

# Local development without Docker (uncomment and use localhost)
# DATABASE_URL=postgresql://terasight:terasight@localhost:5432/terasight
# REDIS_URL=redis://localhost:6379/0
# INFERENCE_SERVICE_URL=http://localhost:8001

# PrithviQ Inference Service
INFERENCE_HOST=0.0.0.0
INFERENCE_PORT=8001

# PostgreSQL
POSTGRES_USER=terasight
POSTGRES_PASSWORD=terasight
POSTGRES_DB=terasight

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
